# =============================================================================
# Interview Platform Backend - Development Environment Variables
# =============================================================================
# Copy this file to .env and update the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Database ---
DB_URL=jdbc:postgresql://localhost:5433/interview_platform
DB_USERNAME=admin
DB_PASSWORD=postgres
DB_POOL_MAX=10

# --- JPA ---
JPA_DDL_AUTO=update

# --- Server ---
SERVER_PORT=8080

# --- Spring Security ---
SPRING_SECURITY_PASSWORD=admin

# --- JWT (REQUIRED - generate secure random strings for production) ---
JWT_SECRET=your-jwt-secret-key-here-min-256-bits
JWT_EXPIRATION=86400000
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here-min-256-bits
JWT_REFRESH_EXPIRATION=1209600000

# --- OAuth2 - Google ---
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- OAuth2 - GitHub ---
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# --- OAuth2 - Microsoft ---
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret

# --- OAuth2 Base URL ---
OAUTH2_BASE_URL=http://localhost:8080

# --- Frontend URL ---
FRONTEND_URL=http://localhost:5173

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# --- AWS S3 / LocalStack (FREE - uses LocalStack, no AWS account needed) ---
AWS_S3_BUCKET_NAME=interview-platform-documents
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY=test
AWS_S3_SECRET_KEY=test
AWS_S3_ENDPOINT=http://localhost:4566
AWS_S3_PRESIGNED_URL_EXPIRY=60

# --- Email (SMTP) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# --- Kafka ---
KAFKA_ENABLED=false
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# --- SMS ---
SMS_ENABLED=false
SMS_PROVIDER=log

# --- Notifications ---
NOTIFICATIONS_ENABLED=true

# --- Slack (Optional) ---
SLACK_ENABLED=false
SLACK_WEBHOOK_URL=

# --- Teams (Optional) ---
TEAMS_ENABLED=false
TEAMS_WEBHOOK_URL=

# --- Docker Compose ---
DOCKER_COMPOSE_ENABLED=true

# --- Observability (OpenTelemetry Java Agent) ---
# The Java agent is attached via -javaagent JVM flag (see Dockerfile).
# All configuration below is passed as environment variables to the agent.
OTEL_SERVICE_NAME=interview-platform-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=service.namespace=interview-platform,deployment.environment=dev
# Disable specific instrumentations if needed (comma-separated):
# OTEL_INSTRUMENTATION_[NAME]_ENABLED=false

# --- Meeting Providers (Optional) ---
ZOOM_API_KEY=
ZOOM_API_SECRET=
GOOGLE_MEET_CLIENT_ID=

# --- Code Execution Engine ---
CODE_EXECUTION_ENABLED=true
CODE_EXECUTION_MAX_TIMEOUT=30000
CODE_EXECUTION_DEFAULT_TIMEOUT=10000
CODE_EXECUTION_MEMORY_LIMIT=268435456
CODE_EXECUTION_MAX_CONCURRENT=10
DOCKER_HOST=unix:///var/run/docker.sock

# --- Account Lockout ---
LOCKOUT_ENABLED=true
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30
LOCKOUT_WINDOW_MINUTES=15
LOCKOUT_MAX_IP_ATTEMPTS=20
LOCKOUT_IP_BLOCK_MINUTES=60
LOCKOUT_ALERTS_ENABLED=true
LOCKOUT_ALERT_THRESHOLD=3
LOCKOUT_IP_BLOCKING=true

# --- SSO/SAML ---
SSO_BASE_URL=http://localhost:8080

# --- Data Encryption at Rest (REQUIRED for production - SOC2/GDPR) ---
# Generate with: openssl rand -base64 32
ENCRYPTION_ENABLED=true
ENCRYPTION_SECRET_KEY=
